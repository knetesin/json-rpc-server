{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block page_title %}JSON-RPC{% endblock %}

{% block menu %}
    {% set call_count = collector.callCount %}
    {% set registered = collector.registeredMethodCount %}
    <span class="label {{ registered > 0 or call_count > 0 ? '' : 'disabled' }} {{ collector.hasError ? 'label-status-red' : (call_count > 0 ? 'label-status-green' : '') }}">
        <span class="icon">{{ source('@KnetesinJsonRpcServer/Collector/icon.svg') }}</span>
        <strong>RPC</strong>
        {% if call_count > 0 %}
            <span class="count">
                <span>{{ call_count }}</span>
            </span>
        {% elseif registered > 0 %}
            <span class="count">
                <span>{{ registered }}</span>
            </span>
        {% endif %}
    </span>
{% endblock %}

{% block toolbar %}
    {% set call_count = collector.callCount %}
    {% set registered = collector.registeredMethodCount %}
    {% set registry = collector.registry %}
    {% if call_count > 0 or registered > 0 %}
        {% set icon %}
            {{ source('@KnetesinJsonRpcServer/Collector/icon.svg') }}
            {% if call_count > 0 %}
                <span class="sf-toolbar-value">{{ call_count }}</span>
                <span class="sf-toolbar-info-piece-additional-detail">
                    <span class="sf-toolbar-label">in</span>
                    <span class="sf-toolbar-value">{{ collector.totalDurationMs }} ms</span>
                </span>
            {% else %}
                <span class="sf-toolbar-value">{{ registered }}</span>
                <span class="sf-toolbar-label">methods</span>
            {% endif %}
        {% endset %}

        {% set text %}
            <div class="sf-toolbar-info-group">
                <div class="sf-toolbar-info-piece">
                    <b>Registered methods</b>
                    <span>{{ registry.total }}</span>
                </div>
                {% if registry.mcp_exposed > 0 %}
                    <div class="sf-toolbar-info-piece">
                        <b>MCP tools</b>
                        <span>{{ registry.mcp_exposed }}</span>
                    </div>
                {% endif %}
                {% if call_count > 0 %}
                    <div class="sf-toolbar-info-piece">
                        <b>Calls this request</b>
                        <span class="sf-toolbar-status {{ collector.hasError ? 'sf-toolbar-status-red' : 'sf-toolbar-status-green' }}">{{ call_count }}</span>
                    </div>
                    <div class="sf-toolbar-info-piece">
                        <b>Total time</b>
                        <span>{{ collector.totalDurationMs }} ms</span>
                    </div>
                    {% if collector.errorCount > 0 %}
                        <div class="sf-toolbar-info-piece">
                            <b>Errors</b>
                            <span class="sf-toolbar-status sf-toolbar-status-red">{{ collector.errorCount }}</span>
                        </div>
                    {% endif %}
                {% else %}
                    <div class="sf-toolbar-info-piece">
                        <b>Calls this request</b>
                        <span>none</span>
                    </div>
                {% endif %}
            </div>
        {% endset %}

        {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url, status: collector.hasError ? 'error' : '' }) }}
    {% endif %}
{% endblock %}

{% block panel %}
    <h2>JSON-RPC</h2>

    {% set registry = collector.registry %}

    <div class="metrics">
        <div class="metric">
            <span class="value">{{ registry.total }}</span>
            <span class="label">Registered</span>
        </div>
        <div class="metric">
            <span class="value">{{ registry.mcp_exposed }}</span>
            <span class="label">MCP exposed</span>
        </div>
        <div class="metric">
            <span class="value">{{ registry.streaming }}</span>
            <span class="label">Streaming</span>
        </div>
        <div class="metric">
            <span class="value">{{ registry.deprecated }}</span>
            <span class="label">Deprecated</span>
        </div>
        <div class="metric">
            <span class="value">{{ registry.secured }}</span>
            <span class="label">Role-protected</span>
        </div>
        <div class="metric">
            <span class="value">{{ registry.cached }}</span>
            <span class="label">Cached</span>
        </div>
        <div class="metric">
            <span class="value">{{ registry.rate_limited }}</span>
            <span class="label">Rate-limited</span>
        </div>
    </div>

    <p class="help">
        Registry counts come from compile-time metadata. Run <code>bin/console debug:rpc</code> for the full method list.
    </p>

    <h3>This request</h3>

    {% if collector.callCount == 0 %}
        <div class="empty">
            <p>No RPC methods were invoked during this request.</p>
        </div>
    {% else %}
        <div class="metrics">
            <div class="metric">
                <span class="value">{{ collector.callCount }}</span>
                <span class="label">Calls</span>
            </div>
            <div class="metric">
                <span class="value">{{ collector.uniqueMethodsCalled }}</span>
                <span class="label">Unique methods</span>
            </div>
            <div class="metric">
                <span class="value">{{ collector.totalDurationMs }} ms</span>
                <span class="label">Total time</span>
            </div>
            {% if collector.errorCount > 0 %}
                <div class="metric">
                    <span class="value">{{ collector.errorCount }}</span>
                    <span class="label">Errors</span>
                </div>
            {% endif %}
            {% if collector.cacheHitCount > 0 %}
                <div class="metric">
                    <span class="value">{{ collector.cacheHitCount }}</span>
                    <span class="label">Cache hits</span>
                </div>
            {% endif %}
        </div>

        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Method</th>
                    <th>Handler</th>
                    <th>Time</th>
                    <th>Status</th>
                    <th>Params</th>
                    <th>Result / Error</th>
                </tr>
            </thead>
            <tbody>
                {% for call in collector.calls %}
                    <tr>
                        <td class="font-normal">{{ loop.index }}</td>
                        <td><code>{{ call.method }}</code></td>
                        <td><span class="text-muted">{{ call.handler|abbr_class }}</span></td>
                        <td class="font-normal">{{ call.duration_ms }} ms{% if call.cache_hit %} <span class="badge badge-success">cache</span>{% endif %}</td>
                        <td>
                            {% if call.status == 'ok' %}
                                <span class="badge badge-success">OK</span>
                            {% elseif call.status == 'error' %}
                                <span class="badge badge-danger">Error</span>
                            {% else %}
                                <span class="badge">{{ call.status }}</span>
                            {% endif %}
                        </td>
                        <td>{{ profiler_dump(call.params) }}</td>
                        <td>
                            {% if call.status == 'error' %}
                                <span class="text-danger">{{ call.exception_class }}: {{ call.exception_message }}</span>
                            {% else %}
                                {{ profiler_dump(call.result) }}
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    {% if collector.dispatchCount > 0 %}
        <h3>Batch dispatches</h3>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Batch size</th>
                    <th>Decision</th>
                    <th>Total time</th>
                    <th>Fan-out depth</th>
                    <th>Inflight at start</th>
                    <th>Sub-call times (ms)</th>
                </tr>
            </thead>
            <tbody>
                {% for dispatch in collector.dispatches %}
                    <tr>
                        <td class="font-normal">{{ loop.index }}</td>
                        <td>{{ dispatch.batch_size }}</td>
                        <td><code>{{ dispatch.decision }}</code></td>
                        <td>{{ dispatch.total_duration_ms }} ms</td>
                        <td>{{ dispatch.fanout_depth }}</td>
                        <td>{{ dispatch.inflight_at_start }}</td>
                        <td class="font-normal">
                            {% if dispatch.subcall_durations_ms is empty %}
                                <span class="text-muted">—</span>
                            {% else %}
                                {{ dispatch.subcall_durations_ms|join(', ') }}
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
